{
  "manifest_version": 3,
  "name": "Find++",
  "description": "Find multiple terms on the current page with modes, colors, and quick navigation.",
  "version": "0.2.0",
  "action": {
    "default_title": "Find++ — Toggle find bar (⌘⇧F)"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "commands": {
    "toggle-find-bar": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Toggle the Find++ bar on the current page"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/shared/search-core.js",
        "assets/icons/findpp.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
